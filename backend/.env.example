# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=your-super-secret-key-change-in-production

# PostgreSQL (required). Use Neon, local Postgres, or any postgresql:// URL.
DATABASE_URL=postgresql://user:password@localhost:5432/body_fat_tracker

# Password reset email (optional: without RESEND_API_KEY, reset link is logged to console)
# FRONTEND_URL=http://localhost:5173
# RESEND_API_KEY=re_xxxx
# RESEND_FROM=Body Fat Tracker <noreply@yourdomain.com>
