# Server
PORT=3001
CORS_ORIGIN=http://localhost:5173

# JWT
JWT_SECRET=your-super-secret-key-change-in-production

# SQLite (local dev) – required for Prisma CLI (migrate, db push)
DATABASE_URL=file:./data/body_fat_tracker.db

# Optional: app also accepts DATABASE_FILE; if set and DATABASE_URL is unset, URL becomes file:<DATABASE_FILE>
# DATABASE_FILE=./data/body_fat_tracker.db

# For production with PostgreSQL, switch provider in prisma/schema.prisma and use:
# DATABASE_URL=postgresql://user:password@localhost:5432/body_fat_tracker
