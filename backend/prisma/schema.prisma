// Body Fat Tracker - Prisma schema (PostgreSQL: Neon, Render, local, etc.)

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                      String   @id @default(uuid())
  email                   String   @unique
  passwordHash            String   @map("password_hash")
  age                     Int
  sex                     String   // 'male' | 'female'
  heightCm                Float    @map("height_cm")
  currentWeightKg         Float    @map("current_weight_kg")
  targetBodyFatPercent    Float    @map("target_body_fat_percent")
  activityLevel           String?  @map("activity_level") // sedentary | light | moderate | very_active
  leanMassKg              Float?   @map("lean_mass_kg")
  units                   String   @default("metric") // "metric" | "imperial"
  passwordResetToken      String?  @map("password_reset_token")
  passwordResetExpiresAt  DateTime? @map("password_reset_expires_at")
  emailVerifiedAt         DateTime? @map("email_verified_at")
  emailVerificationToken  String?  @map("email_verification_token")
  emailVerificationExpiresAt DateTime? @map("email_verification_expires_at")
  onboardingComplete      Boolean  @default(true) @map("onboarding_complete")
  plan                    String?  @default("free") // "free" | "premium" for future feature gating
  createdAt               DateTime @default(now()) @map("created_at")
  updatedAt               DateTime @updatedAt @map("updated_at")

  dailyEntries    DailyEntry[]
  optionalMetrics OptionalMetric[]
  exercises       Exercise[]
  exerciseFavorites UserExerciseFavorite[]
  workouts        Workout[]
  workoutPrograms WorkoutProgram[]
  trainingBlockStartedAt DateTime? @map("training_block_started_at")
  lastCalibrationWeekIndex Int? @map("last_calibration_week_index")
}

/// Global catalog (userId null) or user-created custom exercise
model Exercise {
  id        String   @id @default(uuid())
  userId    String?  @map("user_id")
  name      String
  kind      String   // weight_reps | bodyweight_reps | time
  createdAt DateTime @default(now()) @map("created_at")

  user              User?                @relation(fields: [userId], references: [id], onDelete: Cascade)
  favorites         UserExerciseFavorite[]
  workoutExercises  WorkoutExercise[]
  programDayExercises ProgramDayExercise[]

  @@index([userId])
  @@index([name])
  @@unique([userId, name])
  @@map("exercises")
}

model UserExerciseFavorite {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")
  exerciseId String   @map("exercise_id")
  createdAt  DateTime @default(now()) @map("created_at")

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  exercise Exercise @relation(fields: [exerciseId], references: [id], onDelete: Cascade)

  @@unique([userId, exerciseId])
  @@index([userId])
  @@map("user_exercise_favorites")
}

model WorkoutProgram {
  id          String   @id @default(uuid())
  userId      String   @map("user_id")
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user     User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  days     ProgramDay[]
  workouts Workout[]

  @@index([userId])
  @@map("workout_programs")
}

model ProgramDay {
  id        String   @id @default(uuid())
  programId String   @map("program_id")
  name      String
  orderIndex Int     @map("order_index")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  program   WorkoutProgram         @relation(fields: [programId], references: [id], onDelete: Cascade)
  exercises ProgramDayExercise[]
  workouts  Workout[]

  @@index([programId, orderIndex])
  @@map("program_days")
}

model ProgramDayExercise {
  id                 String   @id @default(uuid())
  programDayId       String   @map("program_day_id")
  exerciseId         String   @map("exercise_id")
  orderIndex         Int      @map("order_index")
  progressionVariant String   @default("general_double") @map("progression_variant")
  notes              String?
  createdAt          DateTime @default(now()) @map("created_at")

  programDay   ProgramDay            @relation(fields: [programDayId], references: [id], onDelete: Cascade)
  exercise     Exercise              @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  setTemplates ProgramDaySetTemplate[]

  @@index([programDayId, orderIndex])
  @@map("program_day_exercises")
}

model ProgramDaySetTemplate {
  id                   String   @id @default(uuid())
  programDayExerciseId String   @map("program_day_exercise_id")
  setIndex             Int      @map("set_index")
  setRole              String   @map("set_role") // top | backoff | working
  targetRepsMin        Int?     @map("target_reps_min")
  targetRepsMax        Int?     @map("target_reps_max")
  targetRirMin         Int?     @map("target_rir_min")
  targetRirMax         Int?     @map("target_rir_max")
  percentOfTop         Float?   @map("percent_of_top")

  programDayExercise ProgramDayExercise @relation(fields: [programDayExerciseId], references: [id], onDelete: Cascade)

  @@index([programDayExerciseId, setIndex])
  @@map("program_day_set_templates")
}

model Workout {
  id                 String    @id @default(uuid())
  userId             String    @map("user_id")
  name               String?
  notes              String?
  startedAt          DateTime  @map("started_at")
  completedAt        DateTime? @map("completed_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  programId          String?   @map("program_id")
  programDayId       String?   @map("program_day_id")
  trainingWeekIndex  Int?      @map("training_week_index")
  isDeloadWeek       Boolean   @default(false) @map("is_deload_week")

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  program     WorkoutProgram?   @relation(fields: [programId], references: [id], onDelete: SetNull)
  programDay  ProgramDay?       @relation(fields: [programDayId], references: [id], onDelete: SetNull)
  exercises   WorkoutExercise[]

  @@index([userId, startedAt])
  @@index([userId, completedAt])
  @@index([programDayId])
  @@map("workouts")
}

model WorkoutExercise {
  id                  String   @id @default(uuid())
  workoutId           String   @map("workout_id")
  exerciseId          String   @map("exercise_id")
  orderIndex          Int      @map("order_index")
  notes               String?
  defaultRestSeconds  Int?     @map("default_rest_seconds")

  workout  Workout      @relation(fields: [workoutId], references: [id], onDelete: Cascade)
  exercise Exercise     @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  sets     WorkoutSet[]

  @@index([workoutId, orderIndex])
  @@map("workout_exercises")
}

model WorkoutSet {
  id                   String   @id @default(uuid())
  workoutExerciseId    String   @map("workout_exercise_id")
  setIndex             Int      @map("set_index")
  weightKg             Float?   @map("weight_kg")
  reps                 Int?
  durationSec          Int?     @map("duration_sec")
  notes                String?
  restSecondsAfter     Int?     @map("rest_seconds_after")
  rir                  Int?     @map("rir")
  setRole              String?  @map("set_role")
  targetRepsMin        Int?     @map("target_reps_min")
  targetRepsMax        Int?     @map("target_reps_max")
  targetRirMin         Int?     @map("target_rir_min")
  targetRirMax         Int?     @map("target_rir_max")
  calibrationToFailure Boolean  @default(false) @map("calibration_to_failure")

  workoutExercise WorkoutExercise @relation(fields: [workoutExerciseId], references: [id], onDelete: Cascade)

  @@index([workoutExerciseId, setIndex])
  @@map("workout_sets")
}

model DailyEntry {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  date      DateTime // stored as date in SQLite
  weightKg  Float    @map("weight_kg")
  calories  Int?
  waistCm   Float?   @map("waist_cm")
  hipCm     Float?   @map("hip_cm")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("daily_entries")
}

model OptionalMetric {
  id              String   @id @default(uuid())
  userId          String   @map("user_id")
  date            DateTime
  bodyFatPercent  Float?   @map("body_fat_percent")
  createdAt       DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@index([userId, date])
  @@map("optional_metrics")
}
