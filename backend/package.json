{
  "name": "body-fat-tracker-api",
  "version": "1.0.0",
  "type": "module",
  "description": "Body Fat Tracker REST API",
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "dev": "prisma generate && tsx watch src/index.ts",
    "test": "vitest run --exclude '**/*.integration.test.ts'",
    "db:push:test": "DATABASE_URL=file:./data/integration_test.db npx prisma db push",
    "test:integration": "npm run db:push:test && TEST_DATABASE_URL=file:./data/integration_test.db vitest run src/api.integration.test.ts",
    "test:watch": "vitest",
    "db:push": "prisma db push",
    "db:seed": "prisma db seed",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:reset": "prisma migrate reset --force"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.4.2",
    "@prisma/client": "^7.4.2",
    "bcryptjs": "^2.4.3",
    "better-sqlite3": "^11.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "jsonwebtoken": "^9.0.2",
    "resend": "^4.0.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.11",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.0",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.10.0",
    "@types/supertest": "^7.2.0",
    "prisma": "^7.4.2",
    "supertest": "^7.2.2",
    "tsx": "^4.6.2",
    "typescript": "^5.3.2",
    "vitest": "^2.0.0"
  }
}
